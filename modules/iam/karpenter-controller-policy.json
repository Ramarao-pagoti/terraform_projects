{
"Version": "2012-10-17",
"Statement": [
{
"Sid": "KarpenterEC2",
"Effect": "Allow",
"Action": [
"ec2:Describe*",
"ec2:RunInstances",
"ec2:CreateFleet",
"ec2:TerminateInstances",
"ec2:CreateLaunchTemplate",
"ec2:DeleteLaunchTemplate",
"ec2:CreateTags",
"eks:DescribeCluster",
"ssm:GetParameter",
"pricing:GetProducts",
"iam:GetInstanceProfile",
"iam:AddRoleToInstanceProfile",
"iam:RemoveRoleFromInstanceProfile",
"iam:DeleteInstanceProfile"
],
"Resource": "*"
},
{
"Sid": "PassNodeRole",
"Effect": "Allow",
"Action": [
"iam:PassRole"
],
"Resource": "arn:aws:iam::030179310796:role/dev-karpenter-role"
}
]
}
